<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004_add_country_to_drivers" author="jan">
        <addColumn tableName="driver_mapping">
            <column name="country" type="VARCHAR(255)" defaultValue="Unknown">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="driver_result">
            <column name="country" type="VARCHAR(255)" defaultValue="Unknown">
                <constraints nullable="false"/>
            </column>
        </addColumn>
        <addColumn tableName="driver_standing">
            <column name="country" type="VARCHAR(255)" defaultValue="Unknown">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>
